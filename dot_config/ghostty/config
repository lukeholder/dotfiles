# Ghostty Terminal Configuration
# https://ghostty.org/docs/config
#
# Location: ~/.config/ghostty/config
# Managed by chezmoi — edit with: chezmoi edit ~/.config/ghostty/config

# ---------------------------------------------------------------------------
# Font
# ---------------------------------------------------------------------------
font-family = "JetBrains Mono"
font-size = 16

# ---------------------------------------------------------------------------
# Theme & Appearance
# ---------------------------------------------------------------------------
theme = "Catppuccin Frappe"

# Window padding (pixels)
window-padding-x = 12
window-padding-y = 10

# Keep the window background slightly transparent
background-opacity = 0.95

# Use native macOS tabs
macos-titlebar-style = "tabs"

# ---------------------------------------------------------------------------
# Shell
# ---------------------------------------------------------------------------
shell-integration = "zsh"

# ---------------------------------------------------------------------------
# Cursor
# ---------------------------------------------------------------------------
cursor-style = "bar"
cursor-style-blink = true

# ---------------------------------------------------------------------------
# Key Bindings
# ---------------------------------------------------------------------------
# Split pane horizontally
keybind = cmd+d=new_split:right

# Split pane vertically
keybind = cmd+shift+d=new_split:down

# Navigate splits
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
